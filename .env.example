# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local example (adjust user, password, host, port, and database name):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/envelope_budget

# Optional pool tuning
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Set to "true" to log SQL queries to the console
DB_LOGGING=false

# ─── Production (Render) ──────────────────────────────────────────────────────
# On Render, set NODE_ENV=production and DATABASE_URL is injected automatically
# from the linked PostgreSQL instance. SSL is enabled when NODE_ENV=production.
